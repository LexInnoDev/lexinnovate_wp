---
import ContactForm from './ContactForm.astro';
---

<section class="section cta-section" id="contacto" aria-labelledby="cta-title">
  <div class="container">
    <div class="cta-card">
      <div class="cta-grid" aria-hidden="true"></div>
      <div class="cta-orb" aria-hidden="true"></div>
      <p class="eyebrow"><span class="eyebrow-dot"></span>Construyamos el siguiente paso</p>
      <h2 id="cta-title">¿Tienes una idea, proceso o problema que podría resolverse con <span class="gradient-text">tecnología?</span></h2>
      <p>Hablemos y diseñemos una solución práctica, escalable y alineada a tu negocio.</p>
      <ContactForm />
    </div>
  </div>
</section>
