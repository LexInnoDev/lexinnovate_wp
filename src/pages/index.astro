---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Products from '../components/Products.astro';
import WhyUs from '../components/WhyUs.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const title = 'LexInnovate | Legal Tech, Software, Automatización e IA';
const description = 'Soluciones de Legal Tech, desarrollo de software, automatización de procesos e inteligencia artificial aplicada para empresas.';
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="contenido">
    <Hero />
    <Services />
    <Products />
    <WhyUs />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
