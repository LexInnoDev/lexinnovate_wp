---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  intro: string;
  updated?: string;
}

const {
  title,
  description,
  heading,
  intro,
  updated = '2 de julio de 2026',
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="contenido" class="legal-main">
    <header class="legal-hero">
      <div class="container legal-container">
        <p class="eyebrow"><span class="eyebrow-dot"></span>Información legal</p>
        <h1>{heading}</h1>
        <p class="legal-intro">{intro}</p>
        <p class="legal-updated">Última actualización: <time datetime="2026-07-02">{updated}</time></p>
      </div>
    </header>
    <div class="container legal-container">
      <article class="legal-content glass-card">
        <slot />
      </article>
      <a class="legal-back" href="/">
        <svg aria-hidden="true" viewBox="0 0 20 20"><path d="M16 10H4m5 5-5-5 5-5"/></svg>
        Volver al inicio
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
